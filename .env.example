# ==========================================
# Agent Playground - 环境配置示例
# 复制此文件为 .env 并修改配置
#
# 平台支持：
# - AMD64/x86_64 (Intel/AMD 处理器)
# - ARM64 (Apple Silicon M1/M2/M3, AWS Graviton)
#
# 脚本会自动检测架构并使用合适的镜像
# ==========================================

# ==========================================
# 应用配置
# ==========================================
API_PORT=8080
WEB_PORT=3000
RUST_LOG=info

# ==========================================
# 数据库配置
# ==========================================
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=agent_platform

# Redis 配置
REDIS_PORT=6379

# Redis 内存限制（Docker 内存限制）
# 可选值: 128m, 256m, 512m, 1g 等
# 默认 256m，可根据服务器内存调整
REDIS_MEMORY_LIMIT=256m

# Qdrant (向量数据库) 配置
QDRANT_PORT=6333

# Neo4j (图数据库) 配置
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# MinIO (对象存储) 配置
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ==========================================
# Docker 平台配置（可选）
# ==========================================
# 用于强制指定 Docker 镜像架构
# 通常脚本会自动检测，但你可以手动覆盖
#
# Intel/AMD 处理器 (x86_64):
# DOCKER_PLATFORM=linux/amd64
#
# Apple Silicon (M1/M2/M3):
# DOCKER_PLATFORM=linux/arm64
#
# 留空让 Docker 自动选择（推荐）:
# DOCKER_PLATFORM=

# ==========================================
# 内部服务 URL (Docker 网络内使用)
# 本地开发时可能需要修改这些值
# ==========================================
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgres://postgres:postgres@localhost:5432/agent_platform
QDRANT_URL=http://localhost:6333
NEO4J_URL=bolt://localhost:7687
NEO4J_AUTH_USER=neo4j
NEO4J_AUTH_PASSWORD=password
